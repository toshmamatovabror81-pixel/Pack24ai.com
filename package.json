{
  "name": "pack24-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:all": "powershell -ExecutionPolicy Bypass -File scripts/dev-all.ps1",
    "dev:mobile": "powershell -ExecutionPolicy Bypass -File scripts/start-mobile-apps.ps1",
    "start:all": "powershell -ExecutionPolicy Bypass -File scripts/start-all-platforms.ps1",
    "start:all:no-mobile": "powershell -ExecutionPolicy Bypass -File scripts/start-all-platforms.ps1 -NoMobile",
    "build": "next build",
    "vercel-build": "npx prisma generate && npx prisma migrate deploy && npm run build",
    "start": "next start",
    "lint": "next lint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:integration": "tsx src/app/api/orders/__tests__/corporate-integration.test.ts",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test e2e/production-smoke.spec.ts e2e/checkout-critical-path.spec.ts",
    "test:e2e:ui": "playwright test --ui",
    "audit:statuses": "tsx scripts/audit-statuses.ts",
    "seed": "tsx prisma/seed.ts",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "prepare": "husky"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@google/genai": "^2.4.0",
    "@prisma/client": "^6.19.2",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.0.4",
    "@types/leaflet": "^1.9.21",
    "@types/three": "^0.182.0",
    "@types/web-push": "^3.6.4",
    "bcryptjs": "^3.0.3",
    "cheerio": "^1.1.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jspdf": "^4.0.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.468.0",
    "next": "15.1.0",
    "next-auth": "^4.24.13",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "qrcode.react": "^4.2.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-is": "^19.2.3",
    "react-leaflet": "^5.0.0",
    "recharts": "^3.6.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "telegraf": "^4.16.3",
    "three": "^0.171.0",
    "uuid": "^13.0.0",
    "web-push": "^3.6.7",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/cheerio": "^0.22.35",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/qrcode.react": "^1.0.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.23",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.1.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "postcss": "^8.5.6",
    "prisma": "^6.19.2",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.21.0",
    "typescript": "^5"
