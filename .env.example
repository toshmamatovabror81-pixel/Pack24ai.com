# ─── Auth ──────────────────────────────────────────────────────────────────────
# Kamida 32 ta belgi, production da o'zgartiring!
AUTH_SECRET="your-32-char-random-secret-here"

# ─── Admin Panel Auth ─────────────────────────────────────────────────────────
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="your-strong-admin-password"
# HMAC imzo kaliti — kamida 32 ta tasodifiy belgi
ADMIN_SECRET="your-32-char-hmac-secret-here"

# ─── Telegram (ixtiyoriy) ──────────────────────────────────────────────────────
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_ADMIN_CHAT_ID=
# CUSTOMER_BOT_TOKEN=
# DRIVER_BOT_TOKEN=
# ADMIN_BOT_TOKEN=
# PACK24ADMIN_BOT_TOKEN=
# PACK24ADMIN_ALLOWED_TELEGRAM_IDS=123456789,987654321
# Dev: npm run dev restartidan keyin botlar jim boʻlsa — avtomatik polling (nodejs)
# TELEGRAM_DEV_AUTO_POLL=true
# TELEGRAM_DEV_POLL_DELAY_MS=2500

# ─── App URL ───────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_APP_URL=https://pack24.uz

# ─── CORS (vergul bilan ajratilgan) ───────────────────────────────────────────
# ALLOWED_ORIGINS=https://pack24.uz,https://www.pack24.uz,http://localhost:3000

# ─── Payment (ixtiyoriy) ───────────────────────────────────────────────────────
# PAYME_MERCHANT_ID=
# CLICK_MERCHANT_ID=
# CLICK_SERVICE_ID=

# ─── Web Push (VAPID) — Push Notifications ─────────────────────────────────────
# Kalitlarni generatsiya qilish: npx web-push generate-vapid-keys
# Keyin npm install web-push @types/web-push
# VAPID_PUBLIC_KEY=BNb...your-public-key...
# VAPID_PRIVATE_KEY=your-private-key...
# VAPID_EMAIL=mailto:admin@pack24.uz

# ─── AI (Gemini) ───────────────────────────────────────────────────────────────
# Google AI Studio → https://aistudio.google.com/apikey
# AI chat (Gemini 2.5 Flash) va semantic search uchun kerak
# Agar bo'sh bo'lsa, AI chat keyword-matching fallback rejimda ishlaydi
# GEMINI_API_KEY=AIzaSy...

