# ─── Database (Neon PostgreSQL) ───────────────────────────────────────────────
# Neon Console → Connection Details
# DATABASE_URL = pooler (PgBouncer), DIRECT_URL = direct connection (migrate uchun)
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require"

# ─── Supabase Storage (ixtiyoriy — faqat rasm yuklash) ────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://xxxx.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_STORAGE_BUCKET="products"

# ─── Auth ──────────────────────────────────────────────────────────────────────
# Kamida 32 ta belgi, production da o'zgartiring!
AUTH_SECRET="your-32-char-random-secret-here"
NEXTAUTH_SECRET="your-32-char-random-secret-here"
# Production: https://pack24.uz | Dev: http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# ─── Admin Panel Auth ─────────────────────────────────────────────────────────
ADMIN_USERNAME="your-admin-username"
ADMIN_PASSWORD="your-strong-admin-password"
ADMIN_SECRET="your-32-char-hmac-secret-here"

# ─── Driver mobile token ──────────────────────────────────────────────────────
DRIVER_TOKEN_SECRET="your-32-char-driver-secret-here"

# ─── Telegram ─────────────────────────────────────────────────────────────────
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_ADMIN_CHAT_ID=
# CUSTOMER_BOT_TOKEN=
# DRIVER_BOT_TOKEN=
# ADMIN_BOT_TOKEN=
# PACK24ADMIN_BOT_TOKEN=
# PACK24ADMIN_ALLOWED_TELEGRAM_IDS=123456789,987654321
# TELEGRAM_WEBHOOK_SECRET=
# TELEGRAM_OPS_SECRET=
# Dev polling (production da webhook ishlatiladi):
# TELEGRAM_DEV_AUTO_POLL=true
# TELEGRAM_DEV_POLL_DELAY_MS=2500

# ─── App URL ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── CORS ─────────────────────────────────────────────────────────────────────
# ALLOWED_ORIGINS=https://pack24.uz,https://www.pack24.uz,http://localhost:3000

# ─── Payment ───────────────────────────────────────────────────────────────────
# PAYME_MERCHANT_ID=
# PAYME_SECRET_KEY=
# PAYME_TEST_SECRET=
# CLICK_MERCHANT_ID=
# CLICK_SERVICE_ID=
# CLICK_SECRET_KEY=
# CLICK_MERCHANT_USER_ID=

# ─── Web Push (VAPID) ─────────────────────────────────────────────────────────
# npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_EMAIL=mailto:admin@pack24.uz
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# ─── Analytics ────────────────────────────────────────────────────────────────
