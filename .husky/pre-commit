#!/usr/bin/env sh

# Gitleaks — sirlar leak bo'lishini oldini olish (CI ham skanerlaydi)
if command -v gitleaks >/dev/null 2>&1; then
  gitleaks detect --source . --verbose --redact --no-git 2>&1
  if [ $? -ne 0 ]; then
    echo "❌ Gitleaks topildi! Commit bekor qilindi."
    echo "Iltimos, sirlarni olib tashlang va qaytadan urinib ko'ring."
    exit 1
  fi
else
  echo "⚠️ gitleaks o'rnatilmagan — lokal skip (GitHub Actions skanerlaydi)"
fi

# TypeScript tekshiruv
npx tsc --noEmit 2>&1
if [ $? -ne 0 ]; then
  echo "⚠️ TypeScript xatolari mavjud. Iltimos, tuzating."
  exit 1
fi
